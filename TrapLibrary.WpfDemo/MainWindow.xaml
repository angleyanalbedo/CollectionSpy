<Window x:Class="Debugging.Traps.WpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Debugging.Traps.WpfDemo"
        mc:Ignorable="d"
        Title="CollectionSpy - PLC Signal Monitor Dashboard" Height="450" Width="800"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="CollectionSpy 🛡️ Live PLC Signal Trap Dashboard" 
                       Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Device List -->
            <GroupBox Grid.Column="0" Header="Live Device State (Bound directly to TrapList)" Margin="0,0,5,0" FontWeight="Bold">
                <DataGrid x:Name="DeviceDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                          HeadersVisibility="Column" RowBackground="White" AlternatingRowBackground="#F9F9F9"
                          IsReadOnly="True" FontWeight="Normal" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Signal ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Device Name" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Temp" Binding="{Binding Temperature, StringFormat={}{0:F1} °C}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- Right: Trap Logs -->
            <GroupBox Grid.Column="1" Header="Trap Alert Logs" Margin="5,0,0,0" FontWeight="Bold">
                <ListBox x:Name="LogListBox" FontWeight="Normal" Background="#1E1E1E" Foreground="#4CAF50" FontFamily="Consolas">
                    <!-- Logs will be inserted here by TrapActions -->
                </ListBox>
            </GroupBox>
        </Grid>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Add Normal Signal" Width="150" Height="35" Margin="5" Click="BtnAddNormal_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="🚨 Add Overheat Signal (Trap!)" Width="200" Height="35" Margin="5" Click="BtnAddCritical_Click" Background="#F44336" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Update Random Item" Width="150" Height="35" Margin="5" Click="BtnUpdate_Click" Background="#FF9800" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Clear All" Width="100" Height="35" Margin="5" Click="BtnClearLogs_Click"/>
        </StackPanel>
    </Grid>
</Window>